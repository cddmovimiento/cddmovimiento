<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="purchase_order_multi_approve" model="ir.actions.server">
        <field name="name">Aprobar múltiples ordenes de compra</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="purchase.model_purchase_order"></field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"></field>
        <field name="state">code</field>
        <field name="code">
            for record in records:
                if record.state == 'to approve':
                    record.button_approve()
        </field>
        <field name="groups_id" eval="[(4,ref('purchase.group_purchase_manager'))]"/>
    </record>
</odoo>
